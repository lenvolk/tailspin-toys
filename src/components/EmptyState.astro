---
interface Props {
    text?: string;
    dataTestid?: string;
    hidden?: boolean;
    id?: string;
}

const { text, dataTestid = 'empty-state', hidden = false, id } = Astro.props;
---

<div
    id={id}
    data-testid={dataTestid}
    class:list={[
        'text-center py-12 bg-slate-800/50 backdrop-blur-sm rounded-xl border border-slate-700',
    ]}
    hidden={hidden || undefined}
    aria-live="polite"
>
    {text ? (
        <p data-testid="empty-state-text" class="text-slate-300">{text}</p>
    ) : (
        <slot />
    )}
</div>
