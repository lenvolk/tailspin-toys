---
import Layout from '../layouts/Layout.astro';
import GameCard from '../components/GameCard.astro';
import PageHero from '../components/PageHero.astro';
import EmptyState from '../components/EmptyState.astro';
import { getDatabase } from '../lib/db';
import { getAllGames } from '../lib/games';

export const prerender = true;

const games = await getAllGames(getDatabase());
const categories = [...new Map(
  games.flatMap((game) => game.category ? [[game.category.id, game.category] as const] : []),
).values()].sort((a, b) => a.name.localeCompare(b.name));
const publishers = [...new Map(
  games.flatMap((game) => game.publisher ? [[game.publisher.id, game.publisher] as const] : []),
).values()].sort((a, b) => a.name.localeCompare(b.name));
---

<Layout title="Tailspin Toys - Crowdfunding your new favorite game!">
  <div class="py-8">
    <PageHero
      title="Welcome to Tailspin Toys"
      subtitle="Find your next game! And maybe even back one! Explore our collection!"
    />

    <div>
      <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <h2 class="text-2xl font-medium text-slate-100">Featured Games</h2>
          <p class="mt-2 text-sm text-slate-400" data-testid="filter-status" aria-live="polite">
            Showing all {games.length} games
          </p>
        </div>

        {games.length > 0 && (
          <form class="rounded-xl border border-slate-700 bg-slate-800/60 p-4 shadow-lg" data-testid="game-filters">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-end">
              {categories.length > 0 && (
                <fieldset>
                  <legend class="mb-2 text-sm font-medium text-slate-200">Categories</legend>
                  <div class="flex flex-wrap gap-3">
                    {categories.map((category) => (
                      <label class="flex items-center gap-2 text-sm text-slate-300">
                        <input
                          type="checkbox"
                          name="category"
                          value={category.id}
                          class="h-4 w-4 rounded border-slate-600 bg-slate-900 text-blue-500 focus:ring-2 focus:ring-blue-500"
                          data-testid={`category-filter-${category.id}`}
                        />
                        <span>{category.name}</span>
                      </label>
                    ))}
                  </div>
                </fieldset>
              )}

              {publishers.length > 0 && (
                <label class="min-w-48 text-sm text-slate-200">
                  <span class="mb-2 block font-medium">Publisher</span>
                  <select
                    name="publisher"
                    class="w-full rounded-lg border border-slate-600 bg-slate-900 px-3 py-2 text-slate-100 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                    data-testid="publisher-filter"
                  >
                    <option value="">All publishers</option>
                    {publishers.map((publisher) => (
                      <option value={publisher.id}>{publisher.name}</option>
                    ))}
                  </select>
                </label>
              )}

              <button
                type="reset"
                class="rounded-lg border border-slate-600 px-3 py-2 text-sm font-medium text-slate-200 transition-colors hover:bg-slate-700 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                data-testid="clear-filters"
              >
                Clear filters
              </button>
            </div>
          </form>
        )}
      </div>

      {games.length === 0 ? (
        <EmptyState text="No games available at the moment." />
      ) : (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" data-testid="games-grid">
          {games.map((game) => <GameCard game={game} />)}
        </div>
      )}
      <p class="hidden py-8 text-center text-slate-400" data-testid="filtered-empty-state">
        No games match the selected filters.
      </p>
    </div>
  </div>
</Layout>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-testid="game-filters"]');
  const cards = [...document.querySelectorAll<HTMLElement>('[data-testid="game-card"]')];
  const status = document.querySelector<HTMLElement>('[data-testid="filter-status"]');
  const emptyState = document.querySelector<HTMLElement>('[data-testid="filtered-empty-state"]');

  const applyFilters = (): void => {
    if (!form) return;

    const selectedCategories = new Set(
      [...form.querySelectorAll<HTMLInputElement>('input[name="category"]:checked')].map(
        (input) => input.value,
      ),
    );
    const selectedPublisher = form.querySelector<HTMLSelectElement>('select[name="publisher"]')?.value ?? '';
    let visibleCount = 0;

    for (const card of cards) {
      const categoryMatches =
        selectedCategories.size === 0 || selectedCategories.has(card.dataset.categoryId ?? '');
      const publisherMatches =
        selectedPublisher === '' || selectedPublisher === (card.dataset.publisherId ?? '');
      const isVisible = categoryMatches && publisherMatches;
      card.hidden = !isVisible;
      card.setAttribute('aria-hidden', String(!isVisible));
      if (isVisible) visibleCount += 1;
    }

    if (status) {
      status.textContent = `Showing ${visibleCount} of ${cards.length} games`;
    }
    emptyState?.classList.toggle('hidden', visibleCount !== 0);
  };

  form?.addEventListener('change', applyFilters);
  form?.addEventListener('reset', () => requestAnimationFrame(applyFilters));
</script>
